# ==========================================
# Polymarket Trading Bot - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# ⚠️ NEVER commit your .env file with real secrets!
# ==========================================

# ==========================================
# Server Settings
# ==========================================
# Port the web interface runs on
PORT=3000

# How often to broadcast stats to connected clients (milliseconds)
STATS_BROADCAST_INTERVAL_MS=10000

# ==========================================
# Trading Mode (IMPORTANT!)
# ==========================================
# Options: "paper" (fake money, safe!) or "live" (real money!)
# Start with "paper" to practice!
TRADING_MODE=paper

# ==========================================
# Polymarket API Settings
# ==========================================
# Get your API keys from: https://polymarket.com
# Required for live trading, optional for paper trading

CLOB_API_URL=https://clob.polymarket.com
CLOB_WS_URL=wss://clob.polymarket.com/ws

# Your Polymarket API credentials (required for live trading)
CLOB_API_KEY=
CLOB_API_SECRET=
CLOB_API_PASSPHRASE=

# ==========================================
# Wallet Settings (Required for Live Trading)
# ==========================================
# Your Ethereum private key (WITHOUT the 0x prefix)
# ⚠️ NEVER share this with anyone!
PRIVATE_KEY=

# Polygon RPC URL (default is public, but you might want your own for reliability)
POLYGON_RPC_URL=https://polygon-rpc.com

# Chain ID (137 = Polygon Mainnet)
CHAIN_ID=137

# ==========================================
# Trading Parameters
# ==========================================
# Minimum edge/profit margin before taking a trade (e.g., 0.05 = 5%)
MIN_EDGE=0.05

# Maximum position size in USDC
MAX_POSITION_SIZE_USDC=100

# Minimum USDC balance required to trade
MIN_BALANCE_USDC=10

# ==========================================
# Speed Trading Settings (Advanced)
# ==========================================
# Enable speed trading feature
ENABLE_SPEED_TRADING=false

# Market identifiers for 5-minute markets (if speed trading)
MARKET_5MIN_CONDITION_ID=
MARKET_5MIN_YES_TOKEN=
MARKET_5MIN_NO_TOKEN=

# Speed trading parameters
LAG_THRESHOLD=0.02
MAX_SPREAD=0.05
THROTTLE_MS=5000
PRICE_HISTORY_SIZE=20
LAST_SECOND_WINDOW_MS=10000
CLOSE_DETECTION_WINDOW_MS=60000

# ==========================================
# Data Storage
# ==========================================
# Directory where trading data is stored
DATA_DIR=./data

# ==========================================
# Admin Settings
# ==========================================
# Secret for admin operations (optional, for protected actions)
ADMIN_SECRET=
